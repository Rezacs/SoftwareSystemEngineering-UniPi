{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Football Player Label Input Schema",
  "type": "object",
  "properties": {
    "player_id": {
      "type": ["string", "number"]
    },
    "source": {
      "type": "string",
      "enum": ["expert", "classifier"]
    },
    "rating": {
      "type": "number",
      "minimum": 1,
      "maximum": 5
    }
  },
  "required": ["player_id", "source", "rating"]
}
